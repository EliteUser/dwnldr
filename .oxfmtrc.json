{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "tabWidth": 2,
  "semi": true,
  "singleQuote": true,
  "jsxSingleQuote": true,
  "trailingComma": "all",
  "ignorePatterns": ["packages/client/dist/**", "packages/server/dist/**", "coverage/**"],
  "sortImports": {
    "ignoreCase": true,
    "groups": [
      "type",
      ["builtin", "external"],
      "internal",
      ["parent", "sibling", "index"],
      ["side_effect", "side_effect_style", "style"]
    ]
  }
}
